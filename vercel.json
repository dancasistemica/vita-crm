{
  "buildCommand": "NODE_OPTIONS=--max-old-space-size=4096 npm run build:dev",
  "installCommand": "npm install",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "VERCEL_BUILD_TIMEOUT": "3600"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
